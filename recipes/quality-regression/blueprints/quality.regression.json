{
  "id": "quality.regression",
  "version": 1,
  "title": "Quality regression",
  "description": "Route for fixing or proving regressions in tests, CI, lint, typecheck, coverage, or generated baselines.",
  "taskKinds": ["code"],
  "workflowModes": ["direct", "branch_pr"],
  "allowedCommands": [
    "agentplane task verify-show <task-id>",
    "failing command reproduction",
    "focused regression check",
    "project quality gate",
    "agentplane verify <task-id> --ok|--rework"
  ],
  "policyModules": [
    ".agentplane/policy/security.must.md",
    ".agentplane/policy/dod.core.md",
    ".agentplane/policy/dod.code.md"
  ],
  "contextBudget": {
    "maxPolicyModules": 3,
    "maxPromptBlocks": 12,
    "rationale": "Regression work needs quality-gate evidence and a narrow code policy set."
  },
  "nodes": [
    { "id": "intake", "kind": "intake", "mode": "deterministic", "required": true },
    {
      "id": "scope",
      "kind": "scope",
      "mode": "deterministic",
      "required": true,
      "evidence": ["assumptions"]
    },
    {
      "id": "context_resolve",
      "kind": "context_resolve",
      "mode": "deterministic",
      "required": true,
      "policyModules": [
        ".agentplane/policy/security.must.md",
        ".agentplane/policy/dod.core.md",
        ".agentplane/policy/dod.code.md"
      ],
      "evidence": ["context_manifest", "sources"]
    },
    {
      "id": "work_unit",
      "kind": "work_unit",
      "mode": "agentic",
      "required": true,
      "evidence": ["changed_paths"]
    },
    {
      "id": "deterministic_check",
      "kind": "deterministic_check",
      "mode": "deterministic",
      "required": true,
      "allowedCommands": ["failing command reproduction", "focused regression check", "project quality gate"],
      "evidence": ["check_result"]
    },
    {
      "id": "verify_record",
      "kind": "verify_record",
      "mode": "record",
      "required": true,
      "protected": true,
      "evidence": ["check_result"]
    },
    {
      "id": "finish",
      "kind": "finish",
      "mode": "deterministic",
      "required": true,
      "protected": true,
      "evidence": ["commit"]
    }
  ],
  "edges": [
    { "from": "intake", "to": "scope" },
    { "from": "scope", "to": "context_resolve" },
    { "from": "context_resolve", "to": "work_unit" },
    { "from": "work_unit", "to": "deterministic_check" },
    { "from": "deterministic_check", "to": "verify_record" },
    { "from": "verify_record", "to": "finish" }
  ],
  "requiredEvidence": [
    {
      "id": "quality.failure",
      "kind": "check_result",
      "required": true,
      "producedBy": "deterministic_check",
      "description": "Original failing command, hosted check, or accepted reproduction note."
    },
    {
      "id": "quality.fix",
      "kind": "changed_paths",
      "required": true,
      "producedBy": "work_unit",
      "description": "Changed paths that address the regression."
    },
    {
      "id": "quality.proof",
      "kind": "check_result",
      "required": true,
      "producedBy": "deterministic_check",
      "description": "Focused regression proof plus broader quality gate when practical."
    },
    {
      "id": "quality.commit",
      "kind": "commit",
      "required": true,
      "producedBy": "finish",
      "description": "Traceable close commit or integration commit."
    }
  ],
  "stopRules": [
    {
      "id": "failure_not_reproduced",
      "severity": "warn",
      "reason": "The original failure was not reproduced; verification must state residual uncertainty."
    },
    {
      "id": "quality_gate_skipped",
      "severity": "approval_required",
      "reason": "A required quality gate was skipped or replaced."
    }
  ]
}
