{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentplane.dev/schemas/catalog-blueprint.schema.json",
  "title": "AgentPlane Catalog Blueprint",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "id", "name", "version", "summary", "definition"],
  "properties": {
    "schema_version": { "const": 1 },
    "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9._-]*$" },
    "name": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "minLength": 1 },
    "summary": { "type": "string", "minLength": 1 },
    "agentplane": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "min_version": { "type": "string" },
        "blueprint_schema_version": { "const": 1 }
      }
    },
    "definition": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "path"],
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9._-]*$" },
        "path": { "type": "string", "minLength": 1 }
      }
    },
    "policy": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "evidence_templates": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "activation": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "mode": { "enum": ["explicit_only"] },
        "recommended_allowed_ids": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "tags": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    }
  }
}
